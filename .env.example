# Cloudflare API token for ACME DNS challenge
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions:
#   - Zone → Zone → Read
#   - Zone → DNS → Edit
# Zone Resources: Include → Specific zone → <your-domain.com>
CLOUDFLARE_API_TOKEN=

# Email address used for Let's Encrypt ACME registration
TRAEFIK_ACME_EMAIL=admin@mydomain.com

# (Optional) Traefik Dashboard
# Domain where the dashboard will be exposed
TRAEFIK_DASHBOARD_DOMAIN=traefik.pr.mydomain.com
# Basic auth user:hash generated with: htpasswd -nb admin yourpassword
# Example: admin:$apr1$H6uskkkW$IgXLP6ewTrSuBkTrqE8wj/
TRAEFIK_DASHBOARD_AUTH=
